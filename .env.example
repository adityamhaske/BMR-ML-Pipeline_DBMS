# ─────────────────────────────────────────────────────────────────────────────
# BMR-ML-Pipeline — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Project ──────────────────────────────────────────────────────────────────
PROJECT_NAME=bmr-ml-pipeline
ENVIRONMENT=local   # local | staging | production

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_ACCOUNT_ID=123456789012

# S3 Buckets
S3_RAW_BUCKET=bmr-ml-raw-data
S3_PROCESSED_BUCKET=bmr-ml-processed-data
S3_EMBEDDINGS_BUCKET=bmr-ml-embeddings
S3_ARTIFACTS_BUCKET=bmr-ml-model-artifacts

# ECR
ECR_REGISTRY=123456789012.dkr.ecr.us-east-1.amazonaws.com
ECR_SERVING_REPO=bmr-ml-serving
ECR_AIRFLOW_REPO=bmr-ml-airflow

# ─── Redshift ─────────────────────────────────────────────────────────────────
REDSHIFT_HOST=bmr-cluster.xxxx.us-east-1.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DB=bmr_warehouse
REDSHIFT_USER=admin
REDSHIFT_PASSWORD=your-redshift-password
REDSHIFT_SCHEMA=public

# Local alternative (DuckDB for dev)
DUCKDB_PATH=./data/local/warehouse.duckdb

# ─── Postgres (Airflow metadata + pgvector) ───────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=airflow
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_VECTOR_DB=bmr_vectors
POSTGRES_VECTOR_USER=bmr
POSTGRES_VECTOR_PASSWORD=bmr_password

# ─── Redis (Airflow Celery broker) ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Airflow ──────────────────────────────────────────────────────────────────
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-base64
AIRFLOW__WEBSERVER__SECRET_KEY=your-webserver-secret-key
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=./

# ─── MLflow ───────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=bmr-customer-segmentation
MLFLOW_S3_ENDPOINT_URL=https://s3.amazonaws.com   # or http://localhost:4566 for LocalStack

# ─── Embedding Pipeline ───────────────────────────────────────────────────────
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=512
EMBEDDING_DEVICE=cpu   # cpu | cuda | mps
EMBEDDING_WORKERS=4
FAISS_INDEX_PATH=./data/faiss_index/

# ─── Segmentation Service ─────────────────────────────────────────────────────
SEGMENTATION_N_CLUSTERS=8
SEGMENTATION_MIN_CLUSTER_SIZE=50
DRIFT_ALERT_THRESHOLD=0.15

# ─── Serving API ──────────────────────────────────────────────────────────────
SERVING_HOST=0.0.0.0
SERVING_PORT=8000
SERVING_WORKERS=2
SERVING_LOG_LEVEL=info
API_KEY=your-api-key-here

# ─── Monitoring ───────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ─── Notifications ────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SNS_ALERT_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:bmr-ml-alerts

# ─── LocalStack (local AWS simulation) ───────────────────────────────────────
LOCALSTACK_ENDPOINT=http://localhost:4566
USE_LOCALSTACK=true   # true for local dev, false for real AWS
